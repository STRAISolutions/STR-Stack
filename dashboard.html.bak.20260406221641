    function executeSlashOrSend(acct) {
      var inputId = acct === 'master' ? 'ghl-master-input' : 'ghl-cc-input';
      var menuId = 'slash-menu-' + acct;
      var input = document.getElementById(inputId);
      var val = input.value.trim();

      document.getElementById(menuId).classList.remove('visible');

      if (!val) return;

      if (val.startsWith('/')) {
        var parts = val.substring(1).split(' ');
        var cmdName = parts[0].toLowerCase().replace(/^ghl\./, '');
        var arg = parts.slice(1).join(' ').trim();

        // Check shorthand first
        var shortcut = slashShortcuts[cmdName];
        if (shortcut) {
          input.value = '';
          var data = Object.assign({}, shortcut.defaults);
          if (arg && shortcut.argField) {
            data[shortcut.argField] = arg;
          }
          ghlQuickSmart(acct, shortcut.action, data, shortcut.desc);
          return;
        }

        // Then check full action names
        var cmd = slashCommands.find(function(c) {
          return c.slash === '/' + cmdName ||
                 c.action === 'ghl.' + cmdName ||
                 c.slash.indexOf(cmdName) >= 0;
        });

        if (cmd) {
          input.value = '';
          var data = {};
          if (arg) {
            if (cmd.params.indexOf('pipeline') >= 0) data.pipeline_id = arg;
            else if (cmd.params.indexOf('query') >= 0) data.query = arg;
            else if (cmd.params.indexOf('contact_id') >= 0) data.contact_id = arg;
          }
          ghlQuickSmart(acct, cmd.action, data, cmd.desc);
          return;
        }

        // Unknown slash command - show help
        input.value = '';
        var msgId = acct === 'master' ? 'ghl-master-messages' : 'ghl-cc-messages';
        appendGHLMsg(msgId, '/' + cmdName, true);
        var helpText = 'Unknown command: /' + cmdName + '\n\nAvailable shortcuts:\n';
        Object.keys(slashShortcuts).forEach(function(k) {
          helpText += '  /' + k + ' — ' + slashShortcuts[k].desc + '\n';
        });
        helpText += '\nType / to see full command list with autocomplete.';
        appendGHLMsg(msgId, helpText, false);
        addToHistory(acct, '/' + cmdName + ' (unknown)');
        return;
      }

      // Natural language
      sendGHL(acct);
    }

    function ghlQuickSmart(acct, action, data, label) {
      var msgId = acct === 'master' ? 'ghl-master-messages' : 'ghl-cc-messages';
      var displayCmd = '/' + (label || action.replace('ghl.',''));
      if (data.query) displayCmd += ' ' + data.query;
      if (data.pipeline_id) displayCmd += ' ' + data.pipeline_id;
      appendGHLMsg(msgId, displayCmd, true);
      addToHistory(acct, displayCmd);
      var thinking = appendGHLMsg(msgId, '...', false);

      fetch('http://134.209.11.87:8000/execute-ghl', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: action, account: acct, data: data })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.success) {
          thinking.textContent = formatGHLResult(action, d.data);
        } else {
          thinking.textContent = 'Error: ' + (d.detail || d.error || d._error || JSON.stringify(d));
          thinking.style.color = 'var(--danger)';
        }
      })
      .catch(function(e) {
        thinking.textContent = 'Error: ' + e.message;
        thinking.style.color = 'var(--danger)';
      });
    }

    function formatGHLResult(action, data) {
      // Smart formatting based on action type
      if (!data) return 'No data returned';

      // Contacts search
      if (action.indexOf('contacts.search') >= 0) {
        var contacts = data.contacts || [];
        var total = data.total || contacts.length;
        var lines = total + ' contacts found\n';
        contacts.slice(0, 10).forEach(function(c) {
          lines += '  ' + (c.contactName || c.firstName + ' ' + c.lastName || 'N/A');
          if (c.email) lines += ' | ' + c.email;
          if (c.phone) lines += ' | ' + c.phone;
          lines += '\n';
        });
        if (total > 10) lines += '  ... and ' + (total - 10) + ' more';
        return lines;
      }

      // Pipelines list
      if (action === 'ghl.pipelines.list') {
        var pipes = data.pipelines || [];
        var lines = pipes.length + ' pipelines\n';
        pipes.forEach(function(p) {
          var stages = (p.stages || []).map(function(s) { return s.name; }).join(', ');
          lines += '\n  ' + p.name + '\n    Stages: ' + stages + '\n';
        });
        return lines;
      }

      // Stage counts
      if (action === 'ghl.pipeline.stage_counts') {
        var lines = data.pipeline_name + ' | ' + data.total_opportunities + ' total\n\n';
        var stages = data.stages || {};
        Object.keys(stages).forEach(function(name) {
          var info = stages[name];
          lines += '  ' + name + ': ' + info.count + '\n';
        });
        return lines;
      }

      // Tags list
      if (action === 'ghl.tags.list') {
        var tags = data.tags || [];
        return tags.length + ' tags\n  ' + tags.map(function(t) { return t.name; }).join(', ');
      }

      // Users list
      if (action === 'ghl.users.list') {
        var users = data.users || [];
        var lines = users.length + ' users\n';
        users.forEach(function(u) {
          lines += '  ' + (u.name || u.firstName + ' ' + u.lastName) + ' | ' + (u.email || '') + ' | ' + (u.role || '') + '\n';
        });
        return lines;
      }

      // Calendars
      if (action === 'ghl.calendars.list') {
        var cals = data.calendars || [];
        var lines = cals.length + ' calendars\n';
        cals.forEach(function(c) {
          lines += '  ' + c.name + (c.isActive !== false ? ' (active)' : ' (inactive)') + '\n';
        });
        return lines;
      }

      // Bulk move
      if (action.indexOf('bulk_move') >= 0) {
        if (data.dry_run) {
          var lines = 'DRY RUN: Would move ' + data.would_move + ' opportunities\n\n';
          (data.opportunities || []).slice(0, 10).forEach(function(o) {
            lines += '  ' + o.name + '\n';
          });
          if (data.would_move > 10) lines += '  ... and ' + (data.would_move - 10) + ' more';
          lines += '\n\nTo execute, use: /bulk_move with dry_run=false';
          return lines;
        }
        return 'Moved ' + data.moved + '/' + data.total_found + ' opportunities. ' + data.errors + ' errors.';
      }

      // Default: pretty JSON truncated
      var json = JSON.stringify(data, null, 2);
      return json.length > 2000 ? json.substring(0, 2000) + '\n... (truncated)' : json;
    }

