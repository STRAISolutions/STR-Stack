<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>STR Solutions USA Command Center</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      color-scheme: light;
      --bg:#f7f7f5;
      --panel:#ffffff;
      --panel-alt:#fafaf8;
      --border:#e8e6e1;
      --text:#1a1a1a;
      --muted:#8c8c8c;
      --accent:#1a1a1a;
      --accent-soft:#f0efe9;
      --gold:#b8976a;
      --gold-soft:#f5f0e8;
      --success:#2d7a4f;
      --warn:#b8860b;
      --danger:#a33;
    }
    * { box-sizing:border-box; }
    body { margin:0; font-family:'DM Sans',system-ui,-apple-system,sans-serif; background:var(--bg); color:var(--text); }
    h1,h2,.kpi-val,.metric,.metric-sm,.stat-val { font-family:'Cormorant Garamond','Georgia',serif; }

    /* ── Header ── */
    header {
      padding:20px 40px 14px;
      display:flex; flex-direction:row; align-items:center; justify-content:space-between;
      border-bottom:1px solid var(--border);
      background:linear-gradient(180deg, #fff 0%, var(--bg) 100%);
    }
    .header-left {
      display:flex; flex-direction:column;
    }
    .logo-mark {
      width:50px; height:50px; border-radius:50%;
      background:linear-gradient(135deg, #2a2a2a 0%, #4a4a4a 50%, #2a2a2a 100%);
      display:flex; align-items:center; justify-content:center;
      box-shadow:0 4px 20px rgba(0,0,0,0.15);
      margin-bottom:0; flex-shrink:0;
    }
    .logo-mark svg { width:30px; height:30px; }
    h1 {
      margin:0; font-size:28px; letter-spacing:0.06em; font-weight:600;
      text-transform:uppercase; color:var(--text);
    }
    .header-sub {
      font-family:'DM Sans',sans-serif; font-size:12px; letter-spacing:0.15em;
      text-transform:uppercase; color:var(--muted); margin-top:4px;
    }
    .pill {
      padding:5px 14px; border-radius:999px;
      background:var(--gold-soft); color:var(--gold);
      font-weight:600; letter-spacing:0.1em; font-size:11px;
      font-family:'DM Sans',sans-serif; margin-top:10px;
      border:1px solid rgba(184,151,106,0.3);
    }
    .pill.warn { background:#fef8ee; color:var(--warn); border-color:rgba(184,134,11,0.3); }
    .pill.danger { background:#fef2f2; color:var(--danger); border-color:rgba(170,51,51,0.3); }

    /* ── Navigation ── */
    nav.tabs {
      display:flex; flex-wrap:wrap; gap:4px; padding:12px 40px;
      border-bottom:1px solid var(--border); justify-content:center;
      background:#fff;
    }
    nav.tabs button {
      background:transparent; border:none; color:var(--muted);
      padding:10px 20px; border-radius:0; font-weight:500;
      cursor:pointer; font-size:12px; transition:all .2s;
      font-family:'DM Sans',sans-serif; letter-spacing:0.08em;
      text-transform:uppercase; border-bottom:2px solid transparent;
    }
    nav.tabs button:hover { color:var(--text); }
    nav.tabs button.active {
      color:var(--text); border-bottom:2px solid var(--gold);
      background:transparent;
    }

    /* ── Layout ── */
    main { padding:28px 40px 60px; max-width:1440px; margin:0 auto; }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; animation:fade .3s ease-in; }
    @keyframes fade { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

    /* ── Cards ── */
    .grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:18px; }
    .card {
      background:var(--panel); border:1px solid var(--border);
      border-radius:12px; padding:22px;
      box-shadow:0 1px 8px rgba(0,0,0,0.04);
    }
    .card h2 {
      margin:0 0 12px; font-size:14px; letter-spacing:0.12em;
      text-transform:uppercase; color:var(--muted); font-weight:600;
      font-family:'DM Sans',sans-serif;
    }
    .metric { font-size:40px; font-weight:600; margin:4px 0; color:var(--text); }
    .metric span { font-size:15px; color:var(--muted); margin-left:8px; font-family:'DM Sans',sans-serif; }
    .metric-sm { font-size:26px; font-weight:600; margin:4px 0; }

    /* ── KPI Cards ── */
    .kpi-card {
      background:var(--panel); border:1px solid var(--border);
      border-radius:12px; padding:28px 24px;
      box-shadow:0 1px 8px rgba(0,0,0,0.04);
      text-align:center; position:relative;
    }
    .kpi-card::after {
      content:''; position:absolute; bottom:0; left:20%; right:20%;
      height:2px; background:linear-gradient(90deg,transparent,var(--gold),transparent);
    }
    .kpi-card .kpi-val { font-size:34px; font-weight:700; margin:10px 0 6px; }
    .kpi-card .kpi-label {
      font-size:11px; color:var(--muted); text-transform:uppercase;
      letter-spacing:0.14em; font-family:'DM Sans',sans-serif; font-weight:600;
    }
    .kpi-card .kpi-delta { font-size:12px; font-weight:500; margin-top:4px; font-family:'DM Sans',sans-serif; }

    /* ── Lists & Links ── */
    ul.list, ol.list { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px; }
    ul.list li, ol.list li {
      background:var(--panel-alt); border:1px solid var(--border);
      border-radius:10px; padding:12px 14px; line-height:1.5;
      font-family:'DM Sans',sans-serif; font-size:13px;
    }
    .links { display:flex; flex-wrap:wrap; gap:10px; }
    .links a {
      text-decoration:none; color:var(--text); background:var(--panel-alt);
      border:1px solid var(--border); border-radius:10px; padding:10px 16px;
      transition:all .2s; font-weight:500; font-size:13px;
      font-family:'DM Sans',sans-serif;
    }
    .links a:hover { background:var(--gold-soft); border-color:var(--gold); }
    pre {
      background:var(--panel-alt); border:1px solid var(--border);
      border-radius:10px; padding:18px; max-height:420px; overflow:auto;
      font-family:'Fira Code',monospace; font-size:12px; color:var(--text);
    }
    label {
      display:block; font-size:12px; color:var(--muted); margin:12px 0 6px;
      font-weight:500; font-family:'DM Sans',sans-serif; letter-spacing:0.04em;
    }
    input {
      width:100%; padding:11px 14px; border-radius:8px;
      border:1px solid var(--border); background:var(--panel-alt);
      color:var(--text); font-size:13px; font-family:'DM Sans',sans-serif;
    }
    .cta {
      margin-top:18px; padding:14px 18px; background:var(--gold-soft);
      border:1px solid rgba(184,151,106,0.3); border-radius:10px;
      font-family:'DM Sans',sans-serif; font-size:13px;
    }
    button.refresh {
      background:var(--accent); color:#fff; border:none;
      border-radius:8px; padding:10px 18px; font-weight:600;
      cursor:pointer; transition:opacity .2s; font-family:'DM Sans',sans-serif;
      font-size:12px; letter-spacing:0.04em;
    }
    button.refresh:hover { opacity:0.8; }
    .subline { color:var(--muted); font-size:12px; margin-top:6px; font-family:'DM Sans',sans-serif; }
    .dot { display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:8px; }
    .dot.up { background:var(--success); box-shadow:0 0 6px rgba(45,122,79,0.4); }
    .dot.down { background:var(--danger); box-shadow:0 0 6px rgba(170,51,51,0.4); }
    .dot.warn { background:var(--warn); box-shadow:0 0 6px rgba(184,134,11,0.4); }
    .svc-row { display:flex; justify-content:space-between; align-items:center; }
    .svc-row .svc-info { flex:1; }
    .svc-row .svc-meta { text-align:right; color:var(--muted); font-size:12px; font-family:'DM Sans',sans-serif; }
    .stat-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:14px; }
    .stat-box {
      background:var(--panel-alt); border:1px solid var(--border);
      border-radius:10px; padding:16px; text-align:center;
    }
    .stat-box .stat-val { font-size:30px; font-weight:600; }
    .stat-box .stat-label {
      font-size:11px; color:var(--muted); text-transform:uppercase;
      letter-spacing:0.1em; margin-top:4px; font-family:'DM Sans',sans-serif;
    }
    .kpi-embed {
      width:100%; border:none; border-radius:10px;
      min-height:500px; background:var(--panel-alt);
    }
    .divider {
      height:1px; background:linear-gradient(90deg,transparent,var(--border),transparent);
      margin:28px 0;
    }
    .section-title {
      font-family:'Cormorant Garamond',serif; font-size:18px; font-weight:600;
      color:var(--text); margin:0 0 16px; letter-spacing:0.04em;
    }

    /* ── Drag-and-Drop Sections ── */
    .drag-section {
      position:relative;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }
    .drag-section.dragging {
      opacity:0.5; transform:scale(0.98);
    }
    .drag-section.drag-over {
      border-top:3px solid var(--gold);
    }
    /* ── Global Clock ── */
    .global-clock {
      display:flex; align-items:center; gap:8px;
      font-family:'Cormorant Garamond',Georgia,serif;
      font-size:18px; font-weight:500; color:var(--text);
      letter-spacing:0.04em;
    }
    .global-clock .clock-label {
      font-family:'DM Sans',sans-serif; font-size:9px;
      color:var(--muted); letter-spacing:0.15em; text-transform:uppercase;
    }
    .global-clock .clock-dot {
      width:6px; height:6px; border-radius:50%; background:var(--success);
      animation:clockPulse 2s ease-in-out infinite;
    }
    @keyframes clockPulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

    .slash-menu {
      position:absolute; bottom:100%; left:0; right:0;
      background:var(--panel); border:1px solid var(--border);
      border-radius:8px; box-shadow:0 -4px 20px rgba(0,0,0,0.12);
      max-height:280px; overflow-y:auto; display:none; z-index:100;
      font-family:'DM Sans',sans-serif;
    }
    .slash-menu.visible { display:block; }
    .slash-item {
      padding:8px 12px; cursor:pointer; border-bottom:1px solid var(--border);
      display:flex; justify-content:space-between; align-items:center;
      transition:background .15s;
    }
    .slash-item:last-child { border-bottom:none; }
    .slash-item:hover, .slash-item.selected { background:var(--gold-soft); }
    .slash-item .slash-cmd { font-family:monospace; font-size:12px; font-weight:600; color:var(--gold); }
    .slash-item .slash-desc { font-size:11px; color:var(--muted); }
    .slash-item .slash-params { font-size:10px; color:var(--muted); font-family:monospace; opacity:0.7; }

    .qbtn {
      background:var(--panel-alt); border:1px solid var(--border); color:var(--muted);
      border-radius:6px; padding:4px 8px; cursor:pointer; font-size:10px;
      font-family:'DM Sans',sans-serif; transition:all .2s;
    }
    .qbtn:hover { border-color:var(--gold); color:var(--text); }

    .drag-handle {
      position:absolute; top:8px; right:8px;
      cursor:grab; color:var(--muted); font-size:18px;
      opacity:0.3; transition:opacity .2s, color .2s; z-index:5;
      user-select:none; padding:4px;
      background:var(--panel); border-radius:4px;
      border:1px solid var(--border);
    }
    .drag-section:hover .drag-handle { opacity:0.6; }
    .drag-handle:hover { opacity:1 !important; color:var(--gold); }
    .drag-handle:active { cursor:grabbing; }

    /* ── Google / Gmail Tab ── */
    .google-sub-tabs {
      display:flex; gap:4px; margin-bottom:18px; flex-wrap:wrap;
    }
    .google-sub-tabs button {
      background:var(--panel-alt); border:1px solid var(--border); color:var(--muted);
      padding:8px 16px; border-radius:8px; font-weight:500;
      cursor:pointer; font-size:11px; transition:all .2s;
      font-family:'DM Sans',sans-serif; letter-spacing:0.06em;
      text-transform:uppercase;
    }
    .google-sub-tabs button:hover { border-color:var(--gold); color:var(--text); }
    .google-sub-tabs button.active {
      background:var(--gold-soft); border-color:var(--gold); color:var(--text);
    }
    .google-sub-panel { display:none; }
    .google-sub-panel.active { display:block; animation:fade .3s ease-in; }
    .node-indicator {
      display:inline-flex; align-items:center; gap:6px;
      padding:6px 12px; border-radius:8px; font-size:11px;
      font-weight:600; font-family:'DM Sans',sans-serif;
      border:1px solid;
    }
    .node-indicator.on { background:#e8f5ee; border-color:#b5dfc5; color:#2d7a4f; }
    .node-indicator.off { background:#fef2f2; border-color:#f0b5b5; color:#a33; }
    .node-indicator.trouble { background:#fff4e6; border-color:#f0c888; color:#c45500; }
    .node-indicator.standby { background:#fef8ee; border-color:#e8d5a0; color:#b8860b; }
    .node-indicator .ni-dot {
      width:8px; height:8px; border-radius:50%;
    }
    .node-indicator.on .ni-dot { background:#2d7a4f; box-shadow:0 0 6px #2d7a4f; }
    .node-indicator.off .ni-dot { background:#a33; }
    .node-indicator.trouble .ni-dot { background:#c45500; animation:pulse 1.5s infinite; }
    .node-indicator.standby .ni-dot { background:#b8860b; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

    /* ── Wire animations ── */
    @keyframes wirePulse {
      0% { stroke-opacity:0.3; stroke-width:2; }
      50% { stroke-opacity:0.9; stroke-width:3.5; }
      100% { stroke-opacity:0.3; stroke-width:2; }
    }
    @keyframes wireGlow {
      0% { filter: drop-shadow(0 0 2px #2d7a4f); }
      50% { filter: drop-shadow(0 0 8px #4ade80); }
      100% { filter: drop-shadow(0 0 2px #2d7a4f); }
    }
    @keyframes dashFlow {
      0% { stroke-dashoffset: 0; }
      100% { stroke-dashoffset: -20; }
    }
    .wire-active {
      animation: wirePulse 1.5s ease-in-out infinite, wireGlow 1.5s ease-in-out infinite, dashFlow 1s linear infinite;
      stroke-dasharray: 8 4;
    }
    .wire-idle {
      stroke-opacity: 0.35;
    }
    .wire-trouble {
      animation: pulse 2s ease-in-out infinite;
    }
    /* Failure badge on nodes */
    .node-fail-badge {
      position:absolute; top:-6px; right:-6px;
      width:16px; height:16px; border-radius:50%;
      background:#dc2626; border:2px solid #fff;
      display:flex; align-items:center; justify-content:center;
      font-size:9px; color:#fff; font-weight:700;
      cursor:help; z-index:10;
      animation: pulse 1.5s infinite;
    }
    .node-tooltip {
      display:none; position:absolute; bottom:calc(100% + 8px); left:50%;
      transform:translateX(-50%); background:#1a1a2e; color:#ffffff;
      padding:10px 14px; border-radius:8px; font-size:10px;
      white-space:nowrap; z-index:100; border:1px solid #333;
      box-shadow:0 4px 16px rgba(0,0,0,0.3);
      line-height:1.5;
    }
    .node-tooltip::after {
      content:''; position:absolute; top:100%; left:50%;
      transform:translateX(-50%); border:5px solid transparent;
      border-top-color:#1a1a2e;
    }
    .drag-section:hover .node-tooltip,
    .node-indicator:hover .node-tooltip { display:block; }

    /* Wire legend additions */
    .wire-legend { display:flex; gap:12px; flex-wrap:wrap; margin-top:6px; }
    .wire-legend-item { display:flex; align-items:center; gap:5px; font-size:10px; color:var(--muted); }
    .wire-legend-line { width:24px; height:3px; border-radius:2px; }

    /* ── Wiring Embed ── */
    .wiring-embed {
      width:100%; border:none; border-radius:10px;
      min-height:800px; background:var(--panel-alt);
    }

    /* ── Config Collapsible ── */
    .config-section { margin-bottom:14px; }
    .config-section-header {
      display:flex; align-items:center; justify-content:space-between;
      padding:12px 16px; background:var(--panel-alt); border:1px solid var(--border);
      border-radius:8px; cursor:pointer; transition:all .2s;
      font-family:'DM Sans',sans-serif; font-size:12px; font-weight:600;
      letter-spacing:0.08em; text-transform:uppercase; color:var(--text);
    }
    .config-section-header:hover { background:var(--gold-soft); }
    .config-section-header .config-chevron {
      transition:transform .3s; font-size:14px; color:var(--muted);
    }
    .config-section-header.collapsed .config-chevron { transform:rotate(-90deg); }
    .config-section-body {
      overflow:hidden; transition:max-height .3s ease, opacity .3s ease;
      max-height:2000px; opacity:1;
    }
    .config-section-body.collapsed {
      max-height:0; opacity:0; padding:0 !important;
    }

    /* ── Wiring Drag & Drop ── */
    .wn-draggable {
      cursor:grab; transition:box-shadow .2s;
    }
    .wn-draggable:active { cursor:grabbing; }
    .wn-draggable.dragging {
      z-index:100 !important; box-shadow:0 6px 24px rgba(0,0,0,0.25) !important;
      opacity:0.9;
    }
    .wiring-grid-overlay {
      position:absolute; top:0; left:0; width:100%; height:100%;
      pointer-events:none; z-index:0; opacity:0;
      transition:opacity .3s;
      background-image:
        linear-gradient(rgba(200,169,110,0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(200,169,110,0.08) 1px, transparent 1px);
      background-size:5% 5%;
    }
    .wiring-grid-overlay.visible { opacity:1; }

    /* ── Enhanced Tooltips ── */
    .wn-tooltip {
      display:none; position:absolute; bottom:calc(100% + 10px); left:50%;
      transform:translateX(-50%); background:#1a1a2e; color:#ffffff;
      padding:12px 16px; border-radius:8px; font-size:11px;
      white-space:nowrap; z-index:200; border:1px solid #333;
      box-shadow:0 4px 20px rgba(0,0,0,0.4);
      line-height:1.6; font-family:'DM Sans',sans-serif;
      max-width:280px; white-space:normal;
    }
    .wn-tooltip::after {
      content:''; position:absolute; top:100%; left:50%;
      transform:translateX(-50%); border:6px solid transparent;
      border-top-color:#1a1a2e;
    }
    .wn-tooltip .tt-title {
      font-weight:700; font-size:12px; margin-bottom:4px;
      display:flex; align-items:center; gap:6px;
    }
    .wn-tooltip .tt-desc { color:#ffffff; font-size:10px; line-height:1.5; }
    .wn-tooltip .tt-fault { color:#f87171; font-size:10px; margin-top:6px; border-top:1px solid #333; padding-top:6px; }
    .wn-draggable:hover .wn-tooltip { display:block; }

    /* -- Change Log -- */
    .changelog-table { width:100%; border-collapse:collapse; font-family:"DM Sans",sans-serif; font-size:12px; }
    .changelog-table th { text-align:left; padding:8px 10px; border-bottom:2px solid var(--border); color:var(--muted); font-size:10px; text-transform:uppercase; letter-spacing:0.08em; }
    .changelog-table td { padding:6px 10px; border-bottom:1px solid var(--border); color:var(--text); }
    .changelog-table tr:hover { background:var(--panel-alt); }
    .changelog-table .cl-time { color:var(--muted); white-space:nowrap; width:120px; }
    .changelog-table .cl-subj { font-weight:600; white-space:nowrap; }
    .changelog-table .cl-detail { color:var(--muted); }
  </style>
</head>
<body>
  <header>
    <div class="header-left">
      <h1>STR Solutions USA <span style="font-size:16px; font-weight:400; letter-spacing:0.12em; color:var(--muted); margin-left:8px;">COMMAND CENTER</span></h1>
      <div style="display:flex; align-items:center; gap:12px; margin-top:6px;">
        <div class="pill" id="global-status">LIVE</div>
      </div>
    </div>
    <div style="display:flex; align-items:center; gap:20px;">
      <div class="global-clock">
        <span class="clock-dot"></span>
        <div>
          <div id="global-clock-time" style="line-height:1;">--:--:-- --</div>
          <div class="clock-label">Eastern Time</div>
        </div>
      </div>
      <div class="logo-mark" style="background:transparent; box-shadow:none; overflow:hidden;">
        <img src="/assets/brand/str-chrome-white.png" alt="STR Solutions" style="width:50px; height:50px; object-fit:contain; border-radius:50%;">
      </div>
    </div>
  </header>

  <nav class="tabs">
    <button class="tab-btn active" data-tab="financials">Financial KPIs</button>
    <button class="tab-btn" data-tab="services">Services</button>
    <button class="tab-btn" data-tab="stack">Stack</button>
    <button class="tab-btn" data-tab="pipeline">Pipeline</button>
    <button class="tab-btn" data-tab="flowise">Flowise</button>
    <button class="tab-btn" data-tab="wiring">Wiring</button>
    <button class="tab-btn" data-tab="google">Google</button>
    <button class="tab-btn" data-tab="activity">Activity</button>
    <button class="tab-btn" data-tab="skills">Skills</button>
    <button class="tab-btn" data-tab="cowork">Cowork</button>
    <button class="tab-btn" data-tab="config">Config</button>
  </nav>

  <main>

    <!-- ─── FINANCIAL KPIs TAB ────────────────────────────────── -->
    <section id="tab-financials" class="tab-panel active">
      <!-- ROW 1: Financial Projections (4 cards) -->
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:16px; margin-bottom:20px;">
        <div class="kpi-card">
