        agency_oauth: 'Agency OAuth (PIT)',
        master_oauth: 'Master Subaccount OAuth',
        callcenter_oauth: 'Call Center OAuth',
        api_key: 'GHL API Key',
        master_location: 'Location ID (Master)',
        callcenter_location: 'Location ID (Call Center)',
        marketplace_client_id: 'Marketplace Client ID',
        api_base: 'API Base URL',
        api_version: 'API Version'
      });

      renderGroup('config-leadgen-fields', configData.leadgen, {
        instantly_key: 'Instantly API Key',
        apollo_key: 'Apollo API Key',
        clay_key: 'Clay API Key',
        airdna_key: 'AirDNA API Key',
        apify_key: 'Apify API Key'
      });

      renderGroup('config-ai-fields', configData.ai_voice, {
        openai_key: 'OpenAI Key',
        anthropic_key: 'Anthropic Key',
        elevenlabs_key: 'ElevenLabs Key',
        vapi_key: 'Vapi API Key',
        discord_token: 'Discord Bot Token'
      });

      renderGroup('config-infra-fields', configData.infra, {
        flowise_url: 'Flowise URL',
        server_ip: 'Server IP',
        make_token: 'Make.com Token',
        slack_token: 'Slack Token',
        google_key: 'Google API Key'
