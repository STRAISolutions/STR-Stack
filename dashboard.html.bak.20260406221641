    function handleSlashInput(input, acct) {
      var val = input.value;
      var menuId = 'slash-menu-' + acct;
      var menu = document.getElementById(menuId);

      if (val.startsWith('/')) {
        var search = val.substring(1).toLowerCase();

        // Also include shorthand shortcuts in the search pool
        var allItems = slashCommands.map(function(cmd) {
          return { slash: cmd.slash, desc: cmd.desc, action: cmd.action, params: cmd.params };
        });
        // Add shorthand entries that aren't already covered
        Object.keys(slashShortcuts).forEach(function(key) {
          var sc = slashShortcuts[key];
          var already = allItems.some(function(item) { return item.slash === '/' + key; });
          if (!already) {
            allItems.push({ slash: '/' + key, desc: sc.desc, action: sc.action, params: sc.argField || '' });
          }
        });

        // Score and filter matches
        var scored = [];
        allItems.forEach(function(cmd) {
          var slashLower = cmd.slash.toLowerCase();
          var descLower = cmd.desc.toLowerCase();
          var actionLower = cmd.action.toLowerCase();
          var score = -1;

          if (search === '') {
            // Just "/" typed - show everything
            score = 0;
          } else if (slashLower === '/' + search) {
            // Exact match
            score = 100;
          } else if (slashLower.indexOf('/' + search) === 0) {
            // Slash command starts with search (e.g. /ca matches /calendars, /campaigns)
            score = 80;
          } else if (slashLower.indexOf(search) >= 0) {
            // Search found within slash command
            score = 60;
          } else if (descLower.indexOf(search) >= 0) {
            // Search found in description
            score = 40;
          } else if (actionLower.indexOf(search) >= 0) {
            // Search found in action name
            score = 20;
          }

          if (score >= 0) {
            scored.push({ cmd: cmd, score: score });
          }
        });

        // Sort: highest score first, then alphabetically by slash name
        scored.sort(function(a, b) {
          if (b.score !== a.score) return b.score - a.score;
          return a.cmd.slash.localeCompare(b.cmd.slash);
        });

        var matches = scored.map(function(s) { return s.cmd; });

        if (matches.length > 0) {
          slashSelectedIdx = -1;
          menu.innerHTML = matches.map(function(cmd, i) {
            // Highlight the matching portion
            var slashDisplay = cmd.slash;
            if (search) {
              var idx = cmd.slash.toLowerCase().indexOf(search);
              if (idx >= 0) {
                slashDisplay = cmd.slash.substring(0, idx) +
                  '<strong style="color:var(--text);">' + cmd.slash.substring(idx, idx + search.length) + '</strong>' +
                  cmd.slash.substring(idx + search.length);
              }
            }
            return '<div class="slash-item' + (i === slashSelectedIdx ? ' selected' : '') +
              '" data-action="' + cmd.action + '" data-params="' + cmd.params +
              '" onclick="selectSlashCommand(\'' + acct + '\',\'' + cmd.action + '\',\'' + cmd.params + '\',\'' + cmd.slash + '\')">' +
              '<div><span class="slash-cmd">' + slashDisplay + '</span> ' +
              '<span class="slash-desc">' + cmd.desc + '</span></div>' +
              '<span class="slash-params">' + (cmd.params || 'no params') + '</span></div>';
          }).join('');
          menu.classList.add('visible');
        } else {
          menu.classList.remove('visible');
        }
      } else {
        menu.classList.remove('visible');
      }
    }

    function handleSlashKey(event, acct) {
      var menuId = 'slash-menu-' + acct;
      var menu = document.getElementById(menuId);
      var items = menu.querySelectorAll('.slash-item');

      if (menu.classList.contains('visible')) {
        if (event.key === 'ArrowDown') {
          event.preventDefault();
          slashSelectedIdx = Math.min(slashSelectedIdx + 1, items.length - 1);
          items.forEach(function(el, i) { el.classList.toggle('selected', i === slashSelectedIdx); });
          return;
        }
        if (event.key === 'ArrowUp') {
          event.preventDefault();
          slashSelectedIdx = Math.max(slashSelectedIdx - 1, 0);
          items.forEach(function(el, i) { el.classList.toggle('selected', i === slashSelectedIdx); });
          return;
        }
        if (event.key === 'Enter' && slashSelectedIdx >= 0 && items[slashSelectedIdx]) {
          event.preventDefault();
          items[slashSelectedIdx].click();
          return;
        }
        if (event.key === 'Escape') {
          menu.classList.remove('visible');
          return;
        }
      }

      if (event.key === 'Enter') {
        event.preventDefault();
        executeSlashOrSend(acct);
      }
    }

