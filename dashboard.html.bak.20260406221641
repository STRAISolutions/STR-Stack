    // ── Drag-and-Drop Reorder ──
    (function initDragDrop() {
      let dragEl = null;
      let dragGroup = null;

      document.querySelectorAll('.drag-handle').forEach(handle => {
        const section = handle.closest('.drag-section');
        section.setAttribute('draggable', 'true');

        section.addEventListener('dragstart', (e) => {
          dragEl = section;
          dragGroup = section.dataset.dragGroup;
          section.classList.add('dragging');
          e.dataTransfer.effectAllowed = 'move';
          e.dataTransfer.setData('text/plain', section.dataset.dragId);
        });

        section.addEventListener('dragend', () => {
          section.classList.remove('dragging');
          document.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
          saveDragOrder(dragGroup);
          dragEl = null;
          dragGroup = null;
        });

        section.addEventListener('dragover', (e) => {
          e.preventDefault();
          if (!dragEl || section === dragEl) return;
          if (section.dataset.dragGroup !== dragGroup) return;
          e.dataTransfer.dropEffect = 'move';
          section.classList.add('drag-over');
        });

        section.addEventListener('dragleave', () => {
          section.classList.remove('drag-over');
        });

        section.addEventListener('drop', (e) => {
          e.preventDefault();
          section.classList.remove('drag-over');
          if (!dragEl || section === dragEl) return;
          if (section.dataset.dragGroup !== dragGroup) return;
          const parent = section.parentNode;
          const siblings = [...parent.querySelectorAll('.drag-section[data-drag-group="' + dragGroup + '"]')];
          const fromIdx = siblings.indexOf(dragEl);
          const toIdx = siblings.indexOf(section);
          if (fromIdx < toIdx) {
            parent.insertBefore(dragEl, section.nextSibling);
          } else {
            parent.insertBefore(dragEl, section);
          }
        });
      });

      // Restore saved order on load
      restoreAllDragOrders();
    })();

    function saveDragOrder(group) {
      const sections = document.querySelectorAll('.drag-section[data-drag-group="' + group + '"]');
      const order = [...sections].map(s => s.dataset.dragId);
      localStorage.setItem('drag-order-' + group, JSON.stringify(order));
    }

    function restoreAllDragOrders() {
      // v2: Clear stale drag orders from before group-fix
      var dragVersion = localStorage.getItem('drag-version');
      if (dragVersion !== 'v2') {
        Object.keys(localStorage).forEach(function(k) {
          if (k.startsWith('drag-order-')) localStorage.removeItem(k);
        });
        localStorage.setItem('drag-version', 'v2');
      }

      const groups = new Set();
      document.querySelectorAll('.drag-section').forEach(s => {
        if (s.dataset.dragGroup) groups.add(s.dataset.dragGroup);
      });
      groups.forEach(group => {
        const saved = localStorage.getItem('drag-order-' + group);
        if (!saved) return;
        try {
          const order = JSON.parse(saved);
          const sections = document.querySelectorAll('.drag-section[data-drag-group="' + group + '"]');
          if (!sections.length) return;
          const parent = sections[0].parentNode;
          const sectionMap = {};
          sections.forEach(s => { sectionMap[s.dataset.dragId] = s; });
          order.forEach(id => {
            if (sectionMap[id]) parent.appendChild(sectionMap[id]);
          });
        } catch(e) {}
      });
    }

