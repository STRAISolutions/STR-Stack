    // ── Wiring Drag-and-Drop with Snap-to-Grid ──
    const GRID_SNAP = 5; // snap to 5% increments

    function initWiringDragDrop() {
      const panel = document.getElementById('wiring-diagram-panel');
      if (!panel) return;
      const nodes = panel.querySelectorAll('.wn-draggable');

      nodes.forEach(node => {
        let isDragging = false;
        let startX, startY, startLeft, startTop;

        node.addEventListener('mousedown', (e) => {
          if (e.target.closest('.wn-tooltip')) return;
          e.preventDefault();
          isDragging = true;
          node.classList.add('dragging');
          const rect = panel.getBoundingClientRect();
          startX = e.clientX;
          startY = e.clientY;
          startLeft = parseFloat(node.style.left);
          startTop = parseFloat(node.style.top);

          const onMove = (e) => {
            if (!isDragging) return;
            const dx = (e.clientX - startX) / rect.width * 100;
            const dy = (e.clientY - startY) / rect.height * 100;
            let newX = Math.max(3, Math.min(97, startLeft + dx));
            let newY = Math.max(3, Math.min(97, startTop + dy));

            // Snap to grid if grid is visible
            const grid = document.getElementById('wiring-grid');
            if (grid && grid.classList.contains('visible')) {
              newX = Math.round(newX / GRID_SNAP) * GRID_SNAP;
              newY = Math.round(newY / GRID_SNAP) * GRID_SNAP;
            }

            node.style.left = newX + '%';
            node.style.top = newY + '%';

            // Redraw wires in real-time
            redrawWires();
          };

          const onUp = () => {
            isDragging = false;
            node.classList.remove('dragging');
            document.removeEventListener('mousemove', onMove);
            document.removeEventListener('mouseup', onUp);

            // Save position
            const nodeId = node.dataset.nodeId;
            const positions = JSON.parse(localStorage.getItem('wiring-node-positions') || '{}');
            positions[nodeId] = { x: parseFloat(node.style.left), y: parseFloat(node.style.top) };
            localStorage.setItem('wiring-node-positions', JSON.stringify(positions));

            // Final wire redraw
            redrawWires();
          };

          document.addEventListener('mousemove', onMove);
          document.addEventListener('mouseup', onUp);
        });
      });
    }

    function redrawWires() {
      // Re-trigger the wire drawing from the last loaded data
      if (!window._lastWiringData) return;
      const data = window._lastWiringData;
      const svg = document.getElementById('wiring-svg');
      const panel = document.getElementById('wiring-diagram-panel');
      if (!svg || !panel) return;
      svg.innerHTML = '';
      const rect = panel.getBoundingClientRect();
      data.wires.forEach(w => {
        const fromEl = document.getElementById('wn-' + w.from);
        const toEl = document.getElementById('wn-' + w.to);
        if (!fromEl || !toEl) return;
        const fr = fromEl.getBoundingClientRect();
        const tr = toEl.getBoundingClientRect();
        const x1 = fr.left + fr.width/2 - rect.left;
        const y1 = fr.top + fr.height/2 - rect.top;
        const x2 = tr.left + tr.width/2 - rect.left;
        const y2 = tr.top + tr.height/2 - rect.top;
        const mx = (x1+x2)/2, my = (y1+y2)/2;
        const curve = Math.min(Math.abs(x2-x1),Math.abs(y2-y1))*0.3;
        const path = document.createElementNS('http://www.w3.org/2000/svg','path');
        path.setAttribute('d','M'+x1+','+y1+' Q'+mx+','+(my-curve)+' '+x2+','+y2);
        const colors = {active:'#22c55e',on:'#2d7a4f',idle:'#999',off:'#a33',trouble:'#c45500'};
        path.setAttribute('stroke', colors[w.status] || '#ccc');
        path.setAttribute('stroke-width', w.status === 'active' ? '2.5' : '2');
        path.setAttribute('fill','none');
        path.setAttribute('stroke-linecap','round');
        if (w.status === 'off') path.setAttribute('stroke-dasharray','6 4');
        if (w.status === 'trouble') path.setAttribute('stroke-dasharray','8 3');
        path.style.opacity = (w.status === 'active') ? '0.85' : '0.45';
        const title = document.createElementNS('http://www.w3.org/2000/svg','title');
        title.textContent = w.label + ' [' + w.status.toUpperCase() + ']';
        path.appendChild(title);
        svg.appendChild(path);
      });
    }

    function toggleWiringGrid() {
      const grid = document.getElementById('wiring-grid');
      const btn = document.getElementById('grid-toggle-btn');
      if (grid) {
        grid.classList.toggle('visible');
        btn.textContent = grid.classList.contains('visible') ? 'Grid: On' : 'Grid: Off';
      }
    }

    function resetWiringPositions() {
      localStorage.removeItem('wiring-node-positions');
      loadWiringData(); // reload with default positions
    }


    // -- Completed Tasks --
    async function loadChangelog() {
      try {
        const resp = await fetch('changelog.json?_=' + Date.now());
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();
        const tbody = document.getElementById('changelog-body');
        if (!data.log || data.log.length === 0) {
          tbody.innerHTML = '<tr><td colspan=4>No tasks logged</td></tr>';
          return;
        }
        // Group by date, show today first
        const today = new Date().toISOString().slice(0,10);
        const todayTasks = data.log.filter(e => (e.time||'').startsWith(today));
        const olderTasks = data.log.filter(e => !(e.time||'').startsWith(today));
        const display = [...todayTasks.reverse(), ...olderTasks.reverse()];
        let html = '';
        let num = todayTasks.length;
        let shownDate = '';
        for (const e of display) {
          const d = (e.time||'').slice(0,10);
          if (d !== shownDate) {
            shownDate = d;
            const isToday = d === today;
            html += '<tr><td colspan=4 style="padding:10px 10px 4px; font-size:11px; font-weight:700; color:' + (isToday ? 'var(--gold)' : 'var(--muted)') + '; letter-spacing:0.08em; text-transform:uppercase; border-bottom:2px solid var(--border);">' + (isToday ? 'TODAY' : d) + '</td></tr>';
            if (!isToday) num = olderTasks.filter(t => (t.time||'').startsWith(d)).length;
          }
          html += '<tr><td style="text-align:center; color:var(--muted); font-weight:600;">' + num + '</td>';
          html += '<td class=cl-time>' + (e.time||'').slice(11) + '</td>';
          html += '<td class=cl-subj>' + (e.subject||'') + '</td>';
          html += '<td class=cl-detail>' + (e.detail||'') + '</td></tr>';
          num--;
        }
        tbody.innerHTML = html;
      } catch (err) {
        document.getElementById('changelog-body').innerHTML = '<tr><td colspan=4>Failed: ' + err.message + '</td></tr>';
      }
    }


    // -- Pending Tasks --
    async function loadPendingTasks() {
      try {
        const resp = await fetch('pending-tasks.json?_=' + Date.now());
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();
        const tbody = document.getElementById('pending-body');
        if (!data.tasks || data.tasks.length === 0) {
          tbody.innerHTML = '<tr><td colspan=4 style="color:var(--muted);">No pending tasks</td></tr>';
          return;
        }
        const priorityColors = {high: 'var(--danger)', medium: 'var(--warn)', low: 'var(--muted)'};
        let html = '';
        data.tasks.forEach((t, i) => {
          const color = priorityColors[t.priority] || 'var(--muted)';
          html += '<tr>';
          html += '<td style="text-align:center; color:var(--muted); font-weight:600;">' + (i+1) + '</td>';
          html += '<td><span style="font-size:10px; font-weight:600; color:' + color + '; text-transform:uppercase;">' + (t.priority||'') + '</span></td>';
          html += '<td class="cl-subj">' + (t.subject||'') + '</td>';
          html += '<td class="cl-detail">' + (t.detail||'') + '</td>';
          html += '</tr>';
        });
        tbody.innerHTML = html;
      } catch (err) {
        document.getElementById('pending-body').innerHTML = '<tr><td colspan=4 style="color:var(--danger);">Failed: ' + err.message + '</td></tr>';
      }
    }

  </script>
