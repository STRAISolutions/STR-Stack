    // ── Token Health ──
    async function loadTokenHealth() {
      try {
        const r = await fetch('token-health.json?_=' + Date.now());
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const data = await r.json();
        const s = data.summary || {};

        document.getElementById('token-total').textContent = s.total || '--';
        document.getElementById('token-live').textContent = s.live || '--';
        document.getElementById('token-dead').textContent = s.dead || '0';
        document.getElementById('token-health-pct').textContent = (s.health_pct || 0) + '%';

        const pill = document.getElementById('token-health-pill');
        const label = document.getElementById('token-health-label');
        if (s.status === 'all_healthy') {
          pill.className = 'node-indicator on';
          label.textContent = 'All Healthy';
        } else if (s.status === 'all_dead') {
          pill.className = 'node-indicator off';
          label.textContent = 'All Dead';
        } else {
          pill.className = 'node-indicator trouble';
          label.textContent = 'Degraded';
        }

        const pctEl = document.getElementById('token-health-pct');
        if (s.health_pct >= 90) pctEl.style.color = 'var(--success)';
        else if (s.health_pct >= 50) pctEl.style.color = 'var(--warn)';
        else pctEl.style.color = 'var(--danger)';

        const checked = data.checked_at ? new Date(data.checked_at).toLocaleString() : '--';
        document.getElementById('token-last-check').textContent = 'Last check: ' + checked;
        const nextDeep = data.next_deep_check ? new Date(data.next_deep_check).toLocaleString() : '--';
        document.getElementById('token-next-deep').textContent = nextDeep;

        const tbody = document.getElementById('token-table-body');
        tbody.innerHTML = '';
        (data.tokens || []).forEach(function(t) {
          if (t.duplicate) return;
          var tr = document.createElement('tr');
          tr.style.borderBottom = '1px solid var(--border)';
          var sDot = t.status === 'live' ? 'up' : 'down';
          var sLabel = t.status === 'live' ? 'LIVE' : 'DEAD';
          var sColor = t.status === 'live' ? 'var(--success)' : 'var(--danger)';
          tr.innerHTML = '<td style="padding:8px 10px;"><strong>' + t.name + '</strong></td>'
            + '<td style="padding:8px 10px;"><code style="font-size:11px; color:var(--gold);">' + t.masked + '</code></td>'
            + '<td style="padding:8px 10px;"><span class="dot ' + sDot + '"></span><span style="color:' + sColor + '; font-weight:600;">' + sLabel + '</span><br/><span class="subline">' + t.detail + '</span></td>'
            + '<td style="padding:8px 10px;"><code style="font-size:10px;">' + t.source + '</code></td>'
            + '<td style="padding:8px 10px; font-size:11px;">' + t.role + '</td>';
          tbody.appendChild(tr);
        });

        var mmDiv = document.getElementById('token-mismatches');
        mmDiv.innerHTML = '';
        if (data.mismatches && data.mismatches.length > 0) {
          data.mismatches.forEach(function(m) {
            var alertDiv = document.createElement('div');
            alertDiv.style.cssText = 'background:rgba(179,134,11,0.08); border:1px solid var(--warn); border-radius:8px; padding:10px 14px; margin-top:8px; font-size:12px;';
            alertDiv.innerHTML = '<strong style="color:var(--warn);">\u26A0 ' + m.issue + '</strong><br/>' + m.detail
              + '<br/><span class="subline">main .env: <code>' + m.env_masked + '</code> \u00B7 SwarmClaw: <code>' + m.swarm_masked + '</code></span>';
            mmDiv.appendChild(alertDiv);
          });
        }
      } catch(e) {
        document.getElementById('token-health-label').textContent = 'Error';
        console.error('Token health load error:', e);
      }
    }


    // ── Newsletter Registry ──
    async function loadNewsletterRegistry() {
      try {
        const resp = await fetch('/assets/newsletters/registry.json?' + Date.now());
        const data = await resp.json();
        const newsletters = data.newsletters || [];
        
        // Update KPI
        const totalEl = document.getElementById('nl-total-sent');
        if (totalEl) totalEl.textContent = newsletters.length;
        
        const tbody = document.getElementById('newsletter-archive-body');
        if (!tbody) return;
        
        if (newsletters.length === 0) {
          tbody.innerHTML = '<tr><td colspan="7" style="text-align:center; color:var(--muted); padding:24px;">No newsletters sent yet.</td></tr>';
          return;
        }
        
        // Sort newest first
        const sorted = [...newsletters].sort((a, b) => {
          const da = a.date + ' ' + a.time;
          const db = b.date + ' ' + b.time;
          return db.localeCompare(da);
        });
        
        tbody.innerHTML = sorted.map((nl, i) => {
          const stripe = i % 2 === 1 ? 'background:var(--panel-alt);' : '';
          const statusColor = nl.status === 'delivered' ? 'var(--success)' : 'var(--warn)';
          const statusIcon = nl.status === 'delivered' ? '&#10003;' : '&#9679;';
          const viewUrl = '/assets/newsletters/' + nl.file;
          return '<tr style="' + stripe + '">'
            + '<td style="padding:10px 12px; border-bottom:1px solid var(--border); white-space:nowrap;"><strong style="color:var(--gold); font-family:Cormorant Garamond,serif; font-size:16px;">Vol: ' + nl.vol.padStart(2, '0') + '</strong></td>'
            + '<td style="padding:10px 12px; border-bottom:1px solid var(--border); white-space:nowrap; font-family:DM Sans,sans-serif;">' + nl.date + '</td>'
            + '<td style="padding:10px 12px; border-bottom:1px solid var(--border); white-space:nowrap; font-family:DM Sans,sans-serif; color:var(--muted);">' + nl.time + '</td>'
            + '<td style="padding:10px 12px; border-bottom:1px solid var(--border); font-family:DM Sans,sans-serif; font-size:12px;">' + nl.subject + '</td>'
            + '<td style="padding:10px 12px; border-bottom:1px solid var(--border); text-align:center; font-family:DM Sans,sans-serif;">' + nl.recipients + '</td>'
            + '<td style="padding:10px 12px; border-bottom:1px solid var(--border); text-align:center;"><span style="color:' + statusColor + '; font-size:11px; font-weight:600; font-family:DM Sans,sans-serif;">' + statusIcon + ' ' + nl.status.charAt(0).toUpperCase() + nl.status.slice(1) + '</span></td>'
            + '<td style="padding:10px 12px; border-bottom:1px solid var(--border); text-align:center;"><a href="' + viewUrl + '" target="_blank" style="color:var(--gold); text-decoration:none; font-weight:600; font-family:DM Sans,sans-serif; font-size:11px; border:1px solid var(--gold); border-radius:4px; padding:4px 10px;">View</a></td>'
            + '</tr>';
        }).join('');
        
      } catch(e) {
        console.error('Newsletter registry load error:', e);
        const tbody = document.getElementById('newsletter-archive-body');
        if (tbody) tbody.innerHTML = '<tr><td colspan="7" style="text-align:center; color:var(--danger); padding:24px;">Failed to load registry</td></tr>';
      }
    }


