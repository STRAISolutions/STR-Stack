  <script>
    const refreshInterval = 60000;
    let countdown = refreshInterval / 1000;

    // Tab switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      });
    });

    function scheduleCountdown() {
      setInterval(() => {
        countdown = countdown <= 0 ? refreshInterval / 1000 : countdown - 1;
        const el = document.getElementById('refresh-countdown');
        if (el) el.textContent = countdown;
      }, 1000);
    }

    function captureSection(text, title) {
      const regex = new RegExp('## ' + title + '\n([\\s\\S]*?)(\n##|$)');
      const match = text.match(regex);
      return match ? match[1].trim() : '';
    }

    function renderList(targetId, lines, fallback) {
      const target = document.getElementById(targetId);
      if (!target) return;
      target.innerHTML = '';
      if (!lines.length) lines = [fallback];
      lines.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item.replace(/^[\-\u2022\d+\.\s]*/, '');
        target.appendChild(li);
      });
    }

    // ── Services Tab ──
    async function loadServices() {
      const svcMeta = {
        openclaw: { name: 'OpenClaw Gateway', desc: 'AI agent gateway' },
        vapi_relay: { name: 'Vapi Relay', desc: 'Voice webhook relay' },
        flowise: { name: 'Flowise / STU', desc: 'AI chatflow engine' },
        funnel: { name: 'Tailscale Funnel', desc: 'Public HTTPS' },
        discord: { name: 'Discord Bot', desc: 'STU agent on Discord' },
      };
      const list = document.getElementById('svc-list');
      list.innerHTML = '';
      let allUp = true;

      try {
        const r = await fetch('service-health.json?_=' + Date.now());
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const data = await r.json();

        document.getElementById('disk-usage').textContent = data.disk?.used_pct + '%';
        document.getElementById('disk-detail').textContent = data.disk?.available + ' available';

        for (const [key, svc] of Object.entries(data.services || {})) {
          const meta = svcMeta[key] || { name: key, desc: '' };
          const li = document.createElement('li');
          li.classList.add('svc-row');
          const status = svc.status === 'up' ? 'up' : 'down';
          const statusText = svc.status === 'up' ? 'HEALTHY' : 'DOWN';
          if (status !== 'up') allUp = false;
          const portLabel = svc.port === 'ws' ? 'WebSocket' : ':' + svc.port;
          li.innerHTML = '<div class="svc-info"><span class="dot ' + status + '"></span><strong>' + meta.name + '</strong><br/><span class="subline">' + meta.desc + '</span></div><div class="svc-meta">' + portLabel + '<br/>' + statusText + '</div>';
          list.appendChild(li);
        }
            markTabSync('services');
      } catch(e) {
        markTabError('services');
        list.innerHTML = '<li>Failed to load: ' + e.message + '</li>';
        allUp = false;
      }

      const pill = document.getElementById('global-status');
      pill.textContent = allUp ? 'ALL SYSTEMS LIVE' : 'DEGRADED';
      pill.className = 'pill' + (allUp ? '' : ' warn');
    }

    // ── Context ──
    async function loadContext() {
      countdown = refreshInterval / 1000;
      try {
        const resp = await fetch('CONTEXT.md?_=' + Date.now());
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const text = await resp.text();
        document.getElementById('context-raw').textContent = text.trim();
        const line = text.match(/Last updated:\s*(.+)/);
        document.getElementById('context-date').textContent = line ? line[1] : '--';
        const active = captureSection(text, 'Active work').split('\n').filter(l => l.trim().startsWith('-'));
        const blockers = captureSection(text, 'Blockers \\(priority order\\)').split('\n').filter(l => /^\d/.test(l.trim()));
        const paths = captureSection(text, 'Key paths').split('\n').filter(l => l.trim().startsWith('-'));
        renderList('active-work', active, 'No items');
        renderList('blockers', blockers, 'No blockers listed');
        renderList('key-paths', paths, 'No paths listed');
            markTabSync('stack');
      } catch (err) {
        markTabError('stack');
        document.getElementById('context-raw').textContent = 'Failed to load: ' + err;
      }
    }

    // ── Skills ──
    function toggleAllSkills(expand) {
      document.querySelectorAll('.cat-skills').forEach(el => el.style.display = expand ? 'block' : 'none');
      document.querySelectorAll('.cat-arrow').forEach(el => el.textContent = expand ? '\u25BC' : '\u25B6');
    }

    async function loadSkills() {
      try {
        const resp = await fetch('skills-list.json?_=' + Date.now());
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();
        const totalEl = document.getElementById('skills-total');
        if (totalEl) totalEl.textContent = data.total ?? '--';
        const countEl = document.getElementById('skills-count');
        if (countEl) countEl.textContent = data.total ?? '--';
        const updEl = document.getElementById('skills-updated');
        if (updEl) updEl.textContent = 'Updated ' + new Date().toLocaleTimeString();
        const list = document.getElementById('skills-list');
        list.innerHTML = '';

        if (data.categories) {
          data.categories.forEach((cat, ci) => {
            const card = document.createElement('div');
            card.className = 'card';
            card.style.cssText = 'padding:0; overflow:hidden;';
            const catId = 'cat-' + ci;

            const header = document.createElement('div');
            header.style.cssText = 'padding:14px 18px; cursor:pointer; display:flex; justify-content:space-between; align-items:center; border-left:3px solid ' + (cat.color || 'var(--gold)') + '; transition:background .15s;';
            header.onmouseenter = () => header.style.background = 'var(--panel-alt)';
            header.onmouseleave = () => header.style.background = 'transparent';
            header.innerHTML = '<div><span style="font-size:16px; margin-right:8px;">' + (cat.icon || '') + '</span><strong style="font-size:14px; font-family:\'Cormorant Garamond\',serif;">' + cat.name + '</strong><span style="font-size:11px; color:var(--muted); margin-left:8px; font-family:\'DM Sans\',sans-serif;">' + cat.skills.length + ' skill' + (cat.skills.length !== 1 ? 's' : '') + '</span></div><span class="cat-arrow" id="arrow-' + catId + '" style="color:var(--muted); font-size:11px;">\u25BC</span>';
            header.onclick = () => {
              const body = document.getElementById(catId);
              const arrow = document.getElementById('arrow-' + catId);
              if (body.style.display === 'none') { body.style.display = 'block'; arrow.textContent = '\u25BC'; }
              else { body.style.display = 'none'; arrow.textContent = '\u25B6'; }
            };
            card.appendChild(header);

