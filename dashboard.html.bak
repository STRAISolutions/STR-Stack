            <button onclick="stuQuick('Check Instantly campaigns')" style="background:var(--panel-alt);border:1px solid var(--border);color:var(--muted);border-radius:6px;padding:6px 10px;cursor:pointer;font-size:11px;font-family:'DM Sans',sans-serif;">Instantly</button>
            <button onclick="stuQuick('Look up contact info@strsolutionsusa.com in GHL')" style="background:var(--panel-alt);border:1px solid var(--border);color:var(--muted);border-radius:6px;padding:6px 10px;cursor:pointer;font-size:11px;font-family:'DM Sans',sans-serif;">GHL Lookup</button>
          </div>
        </div>

        <!-- Claude Chat -->
        <div class="card" style="display:flex; flex-direction:column; height:600px;">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <h2 style="margin:0; font-family:'Cormorant Garamond',serif; font-size:18px;">Claude</h2>
            <span class="pill warn" id="claude-status-pill" style="font-size:10px;">PENDING KEY</span>
          </div>
          <div class="subline" style="margin-bottom:10px;">Analysis &middot; Code generation &middot; Strategy &middot; Research</div>
          <div id="claude-messages" style="flex:1; overflow-y:auto; display:flex; flex-direction:column; gap:8px; padding:10px 0;">
            <div style="background:var(--gold-soft); border-radius:10px; padding:10px 14px; align-self:flex-start; max-width:85%; font-size:13px; font-family:'DM Sans',sans-serif;">Claude is ready to connect. Add your Anthropic API key to unlock strategy, code analysis, and deep research.</div>
          </div>
          <div style="display:flex; gap:8px; margin-top:8px;">
            <input type="text" id="claude-input" placeholder="Waiting for Anthropic API key..." style="flex:1;" disabled onkeydown="if(event.key==='Enter')sendClaude()" />
            <button class="refresh" onclick="sendClaude()" id="claude-send-btn" disabled style="white-space:nowrap; opacity:0.4;">Send</button>
          </div>
          <div class="cta" style="margin-top:8px; padding:10px 14px; font-size:11px;">
            To activate: add <code>ANTHROPIC_API_KEY</code> to <code>/root/.openclaw/.env</code>, then reload.
          </div>
        </div>

      </div>

      <!-- Entry Points & GitHub -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-top:18px;">
        <div class="card">
          <h2>Entry Points</h2>
          <div class="links">
            <a href="https://flowise.strsolutionsusa.com/" target="_blank">Flowise UI</a>
            <a href="https://discord.com/channels/1472376607166697586" target="_blank">Discord STU</a>
            <a href="https://dashboard.vapi.ai/" target="_blank">Vapi Dashboard</a>
            <a href="https://app.gohighlevel.com/" target="_blank">GHL CRM</a>
            <a href="https://app.instantly.ai/" target="_blank">Instantly</a>
            <a href="https://app.clay.com/" target="_blank">Clay</a>
            <a href="https://app.apollo.io/" target="_blank">Apollo</a>
            <a href="https://us2.make.com/" target="_blank">Make.com</a>
          </div>
        </div>
        <div class="card">
          <h2>GitHub</h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:13px;">Repo: <a href="https://github.com/STRAISolutions/Stack" target="_blank" style="color:var(--gold);">STRAISolutions/Stack</a></p>
          <p style="font-family:'DM Sans',sans-serif; font-size:13px;">Branch: <code>devin/1773159064-hospitality-scraper</code></p>
          <p style="font-family:'DM Sans',sans-serif; font-size:13px;">Logs tracked in <code>Stack/logs/</code></p>
        </div>
      </div>
    </section>

    <!-- ─── CONFIG TAB ──────────────────────────────────────── -->
    <section id="tab-config" class="tab-panel">
      <div class="grid">
        <div class="card">
          <h2>GHL (GoHighLevel)</h2>
          <label>Agency OAuth (PIT)</label>
          <input type="text" value="pit-e19a0be3-b73e-45d6-b316-ad17a76df45c" readonly />
          <label>Master Subaccount OAuth</label>
          <input type="text" value="pit-4b3979a4-bbb0-4bfe-99ef-b30ee3782cc7" readonly />
          <label>Call Center OAuth (JWT)</label>
          <input type="text" value="pit-290a13bb-76e4-4d41-8e84-40629ea6b701" readonly />
          <label>Location ID (Master)</label>
          <input type="text" value="1OOZ4AKIgxO8QKKMnIcK" readonly />
          <label>Location ID (Call Center)</label>
          <input type="text" value="7hTDBClatcBgmUv36bZX" readonly />
        </div>
        <div class="card">
          <h2>Lead Gen / Outreach</h2>
          <label>Instantly API Key</label>
          <input type="text" value="NDI1M2E...mpOb2x4WFdDTnVnYg==" readonly />
          <label>Apollo API Key</label>
          <input type="text" value="NWt_5gpS9thDdeYiBPbc2g" readonly />
          <label>Clay API Key</label>
          <input type="text" value="3bb1e2be39f726488871" readonly />
          <label>AirDNA API Key</label>
          <input type="text" value="f0cd7cc942a6429da4e59308bae7e48a" readonly />
        </div>
        <div class="card">
          <h2>AI / Voice</h2>
          <label>OpenAI Key</label>
          <input type="text" value="sk-proj-***...HKWh6*** (valid)" readonly />
          <label>Vapi Agent ID (PAM)</label>
          <input type="text" value="48cc1c2e-23dc-40b9-8f71-add20d210a5d" readonly />
          <label>ElevenLabs</label>
          <input type="text" value="sk_a601e26c...cdfc" readonly />
          <label>Discord Bot Token</label>
          <input type="text" value="MTQ3MjM0...*** (active)" readonly />
        </div>
        <div class="card">
          <h2>Infrastructure</h2>
          <label>Flowise URL</label>
          <input type="text" value="https://flowise.strsolutionsusa.com" readonly />
          <label>Flowise Login</label>
          <input type="text" value="mike@strsolutionsusa.com / StrStack2026" readonly />
          <label>Server IP</label>
          <input type="text" value="134.209.11.87" readonly />
          <label>Tailscale</label>
          <input type="text" value="openclaw-droplet.tailb44e91.ts.net (Funnel active)" readonly />
          <label>Make.com Scenario</label>
          <input type="text" value="c95c833a-7438-4cda-bc99-628c18bb1105" readonly />
          <label>Make.com Webhook URL</label>
