      <div class="cta" style="margin-top:18px;">
        Keys live in <code>/root/.openclaw/.env</code> and <code>/root/str-stack/.env</code>. Masterkey sheet: <code>/root/str-stack/masterkey_list.csv</code>.
      </div>
    </section>

  </main>

  <script>
    const refreshInterval = 60000;
    let countdown = refreshInterval / 1000;

    // Tab switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      });
    });

    function scheduleCountdown() {
      setInterval(() => {
        countdown = countdown <= 0 ? refreshInterval / 1000 : countdown - 1;
        const el = document.getElementById('refresh-countdown');
        if (el) el.textContent = countdown;
      }, 1000);
    }

    function captureSection(text, title) {
      const regex = new RegExp('## ' + title + '\n([\\s\\S]*?)(\n##|$)');
      const match = text.match(regex);
      return match ? match[1].trim() : '';
    }

    function renderList(targetId, lines, fallback) {
      const target = document.getElementById(targetId);
      if (!target) return;
      target.innerHTML = '';
      if (!lines.length) lines = [fallback];
      lines.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item.replace(/^[\-\u2022\d+\.\s]*/, '');
        target.appendChild(li);
      });
    }

    // ── Services Tab ──
    async function loadServices() {
      const svcMeta = {
        openclaw: { name: 'OpenClaw Gateway', desc: 'AI agent gateway' },
        vapi_relay: { name: 'Vapi Relay', desc: 'Voice webhook relay' },
        flowise: { name: 'Flowise / STU', desc: 'AI chatflow engine' },
        funnel: { name: 'Tailscale Funnel', desc: 'Public HTTPS' },
        discord: { name: 'Discord Bot', desc: 'STU agent on Discord' },
      };
      const list = document.getElementById('svc-list');
      list.innerHTML = '';
      let allUp = true;

      try {
        const r = await fetch('service-health.json?_=' + Date.now());
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const data = await r.json();

        document.getElementById('disk-usage').textContent = data.disk?.used_pct + '%';
        document.getElementById('disk-detail').textContent = data.disk?.available + ' available';

        for (const [key, svc] of Object.entries(data.services || {})) {
          const meta = svcMeta[key] || { name: key, desc: '' };
          const li = document.createElement('li');
          li.classList.add('svc-row');
          const status = svc.status === 'up' ? 'up' : 'down';
          const statusText = svc.status === 'up' ? 'HEALTHY' : 'DOWN';
          if (status !== 'up') allUp = false;
          const portLabel = svc.port === 'ws' ? 'WebSocket' : ':' + svc.port;
          li.innerHTML = '<div class="svc-info"><span class="dot ' + status + '"></span><strong>' + meta.name + '</strong><br/><span class="subline">' + meta.desc + '</span></div><div class="svc-meta">' + portLabel + '<br/>' + statusText + '</div>';
          list.appendChild(li);
        }
      } catch(e) {
        list.innerHTML = '<li>Failed to load: ' + e.message + '</li>';
        allUp = false;
      }

      const pill = document.getElementById('global-status');
      pill.textContent = allUp ? 'ALL SYSTEMS LIVE' : 'DEGRADED';
      pill.className = 'pill' + (allUp ? '' : ' warn');
    }

    // ── Context ──
    async function loadContext() {
      countdown = refreshInterval / 1000;
      try {
        const resp = await fetch('CONTEXT.md?_=' + Date.now());
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const text = await resp.text();
        document.getElementById('context-raw').textContent = text.trim();
        const line = text.match(/Last updated:\s*(.+)/);
        document.getElementById('context-date').textContent = line ? line[1] : '--';
        const active = captureSection(text, 'Active work').split('\n').filter(l => l.trim().startsWith('-'));
        const blockers = captureSection(text, 'Blockers \\(priority order\\)').split('\n').filter(l => /^\d/.test(l.trim()));
        const paths = captureSection(text, 'Key paths').split('\n').filter(l => l.trim().startsWith('-'));
        renderList('active-work', active, 'No items');
        renderList('blockers', blockers, 'No blockers listed');
        renderList('key-paths', paths, 'No paths listed');
      } catch (err) {
        document.getElementById('context-raw').textContent = 'Failed to load: ' + err;
      }
    }

    // ── Skills ──
    function toggleAllSkills(expand) {
      document.querySelectorAll('.cat-skills').forEach(el => el.style.display = expand ? 'block' : 'none');
      document.querySelectorAll('.cat-arrow').forEach(el => el.textContent = expand ? '\u25BC' : '\u25B6');
    }

    async function loadSkills() {
      try {
        const resp = await fetch('skills-list.json?_=' + Date.now());
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();
        const totalEl = document.getElementById('skills-total');
        if (totalEl) totalEl.textContent = data.total ?? '--';
        const countEl = document.getElementById('skills-count');
        if (countEl) countEl.textContent = data.total ?? '--';
        const updEl = document.getElementById('skills-updated');
        if (updEl) updEl.textContent = 'Updated ' + new Date().toLocaleTimeString();
        const list = document.getElementById('skills-list');
        list.innerHTML = '';

        if (data.categories) {
          data.categories.forEach((cat, ci) => {
            const card = document.createElement('div');
            card.className = 'card';
            card.style.cssText = 'padding:0; overflow:hidden;';
            const catId = 'cat-' + ci;

            const header = document.createElement('div');
            header.style.cssText = 'padding:14px 18px; cursor:pointer; display:flex; justify-content:space-between; align-items:center; border-left:3px solid ' + (cat.color || 'var(--gold)') + '; transition:background .15s;';
            header.onmouseenter = () => header.style.background = 'var(--panel-alt)';
            header.onmouseleave = () => header.style.background = 'transparent';
            header.innerHTML = '<div><span style="font-size:16px; margin-right:8px;">' + (cat.icon || '') + '</span><strong style="font-size:14px; font-family:\'Cormorant Garamond\',serif;">' + cat.name + '</strong><span style="font-size:11px; color:var(--muted); margin-left:8px; font-family:\'DM Sans\',sans-serif;">' + cat.skills.length + ' skill' + (cat.skills.length !== 1 ? 's' : '') + '</span></div><span class="cat-arrow" id="arrow-' + catId + '" style="color:var(--muted); font-size:11px;">\u25BC</span>';
            header.onclick = () => {
              const body = document.getElementById(catId);
              const arrow = document.getElementById('arrow-' + catId);
              if (body.style.display === 'none') { body.style.display = 'block'; arrow.textContent = '\u25BC'; }
              else { body.style.display = 'none'; arrow.textContent = '\u25B6'; }
            };
            card.appendChild(header);

            const body = document.createElement('div');
            body.id = catId;
            body.className = 'cat-skills';
            body.style.cssText = 'padding:0 18px 14px; display:block;';

            cat.skills.forEach((skill, si) => {
              const skillDiv = document.createElement('div');
              skillDiv.style.cssText = 'background:var(--panel-alt); border:1px solid var(--border); border-radius:8px; padding:12px 14px; margin-top:10px; cursor:pointer; transition:border-color .2s;';
              skillDiv.onmouseenter = () => skillDiv.style.borderColor = cat.color || 'var(--gold)';
              skillDiv.onmouseleave = () => skillDiv.style.borderColor = 'var(--border)';
              const detailId = 'sd-' + ci + '-' + si;
              skillDiv.innerHTML = '<div style="display:flex; justify-content:space-between; align-items:center;"><strong style="font-size:12px; font-family:\'DM Sans\',sans-serif;">' + skill.name + '</strong><span style="font-size:9px; color:var(--success); font-weight:600; font-family:\'DM Sans\',sans-serif;">READY</span></div><div id="' + detailId + '" style="display:none; margin-top:10px; padding-top:10px; border-top:1px solid var(--border); font-size:12px; line-height:1.6; font-family:\'DM Sans\',sans-serif;"><p style="margin:0 0 8px; color:var(--text);">' + (skill.description || '') + '</p>' + (skill.trigger ? '<p style="margin:0; font-size:11px; color:var(--muted);"><strong style="color:' + (cat.color || 'var(--gold)') + ';">Trigger:</strong> ' + skill.trigger + '</p>' : '') + '</div>';
              skillDiv.onclick = (e) => { e.stopPropagation(); const d = document.getElementById(detailId); d.style.display = d.style.display === 'none' ? 'block' : 'none'; };
              body.appendChild(skillDiv);
            });

            card.appendChild(body);
            list.appendChild(card);
          });
        }
      } catch (err) {
        const countEl = document.getElementById('skills-count');
        if (countEl) countEl.textContent = '~~';
      }
    }

    // ── Flowise Health ──
    async function loadFlowiseHealth() {
      try {
        const resp = await fetch('flowise-health.json?_=' + Date.now());
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();
        document.getElementById('flowise-checked').textContent = data.checked_at ?? '--';
        document.getElementById('flowise-http-code').textContent = data.http_probe?.status_code ?? '--';
        document.getElementById('flowise-http-url').textContent = data.http_probe?.url ?? '';
        const list = document.getElementById('flowise-health-list');
        list.innerHTML = '';
        (data.containers || []).forEach(item => {
          const li = document.createElement('li');
          li.innerHTML = '<span class="dot ' + (item.status?.includes('Up') ? 'up' : 'down') + '"></span><strong>' + item.name + '</strong> &middot; ' + item.status + '<br/><small>' + item.image + ' &mdash; ' + item.ports + '</small>';
          list.appendChild(li);
        });
      } catch (err) {
        document.getElementById('flowise-health-list').innerHTML = '<li>Failed: ' + err + '</li>';
      }
    }

    // ── Flowise Stats ──
    async function loadFlowiseStats() {
      try {
        const resp = await fetch('flowise-stats.json?_=' + Date.now());
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const d = await resp.json();
        document.getElementById('stats-timestamp').textContent = d.timestamp ?? '--';
        document.getElementById('stat-flows').textContent = d.flows?.total ?? '--';
        document.getElementById('stat-deployed').textContent = d.flows?.deployed ?? '--';
        document.getElementById('stat-exec-total').textContent = d.executions?.total ?? '--';
        document.getElementById('stat-exec-24h').textContent = d.executions?.last_24h ?? '--';
        document.getElementById('stat-exec-7d').textContent = d.executions?.last_7d ?? '--';
        document.getElementById('stat-tools').textContent = d.tools ?? '--';
        document.getElementById('stat-fb-up').textContent = d.feedback?.positive ?? '0';
        document.getElementById('stat-fb-down').textContent = d.feedback?.negative ?? '0';
      } catch (err) {
        document.getElementById('stats-timestamp').textContent = 'error';
      }
    }

    // ── Financial KPIs ──
    async function loadKPIs() {
      try {
        const r = await fetch('financial-kpis.json?_=' + Date.now());
        if (!r.ok) return;
        const d = await r.json();
        const fmt = (n) => typeof n === 'number' ? '$' + n.toLocaleString() : '--';

        // Primary KPIs
        const ltv = d.pipeline?.ltv_pipeline;
        const monthly = d.pipeline?.monthly_gross;
        const hot = d.pipeline?.hot_leads;

        document.getElementById('kpi-ltv').textContent = ltv != null ? fmt(ltv) : '--';
        document.getElementById('kpi-ltv-formula').textContent = (hot || 0) + ' hot leads \u00d7 $' + ((d.pipeline?.ltv_per_account || 8000)).toLocaleString() + ' LTV';
        document.getElementById('kpi-ltv-detail').textContent = d.pipeline?.total + ' total pipeline opportunities';

        document.getElementById('kpi-monthly').textContent = monthly != null ? fmt(monthly) + '/mo' : '--';
        document.getElementById('kpi-monthly-formula').textContent = (hot || 0) + ' hot leads \u00d7 $' + (d.pipeline?.monthly_per_account || 750) + '/mo';
        document.getElementById('kpi-monthly-detail').textContent = 'Qualified-Booked + Routed to Call Center';

        document.getElementById('kpi-hotleads').textContent = hot != null ? hot.toLocaleString() : '--';
        document.getElementById('kpi-hotleads-detail').textContent = d.pipeline?.open + ' open | ' + d.pipeline?.lost + ' lost | ' + d.pipeline?.won + ' won';

        // Secondary
        document.getElementById('kpi-total-opps').textContent = d.pipeline?.total?.toLocaleString() ?? '--';
        document.getElementById('kpi-total-detail').textContent = d.pipeline?.open + ' open / ' + d.pipeline?.lost + ' lost / ' + d.pipeline?.won + ' won';
        document.getElementById('kpi-demos').textContent = d.demos?.booked ?? '--';
        document.getElementById('kpi-demos-delta').textContent = 'Target: ' + (d.demos?.target || 30) + '/day';
        document.getElementById('kpi-leads').textContent = d.leads?.total?.toLocaleString() ?? '--';
        document.getElementById('kpi-leads-delta').textContent = d.leads?.active_campaigns + ' active / ' + d.leads?.total_campaigns + ' campaigns';
        document.getElementById('kpi-conversion').textContent = (d.conversion?.rate || 0) + '%';

        // Stage breakdown
        const breakdown = d.pipeline?.hot_stage_breakdown || {};
        const container = document.getElementById('stage-breakdown');
        container.innerHTML = '';
        for (const [stage, count] of Object.entries(breakdown)) {
          const box = document.createElement('div');
          box.className = 'stat-box';
          box.innerHTML = '<div class="stat-val" style="color:var(--gold);">' + count + '</div><div class="stat-label">' + stage + '</div>';
          container.appendChild(box);
        }
        // Show all-stages breakdown below if data exists
        const allBreakdown = d.pipeline?.all_stage_breakdown || {};
        if (Object.keys(allBreakdown).length > 0) {
          const allContainer = document.createElement('div');
          allContainer.style.cssText = 'grid-column:1/-1; margin-top:16px; padding-top:16px; border-top:1px solid var(--border);';
          allContainer.innerHTML = '<div style="font-size:12px; color:var(--muted); margin-bottom:10px; font-family:\'DM Sans\',sans-serif; letter-spacing:0.08em; text-transform:uppercase;">All Open Stages</div>';
          const grid = document.createElement('div');
          grid.style.cssText = 'display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:8px;';
          for (const [stage, count] of Object.entries(allBreakdown)) {
            const isHot = stage === 'Qualified - Booked' || stage === 'Routed to Call Center';
            const box = document.createElement('div');
            box.style.cssText = 'background:' + (isHot ? 'var(--gold-soft)' : 'var(--panel-alt)') + '; border:1px solid ' + (isHot ? 'rgba(184,151,106,0.3)' : 'var(--border)') + '; border-radius:8px; padding:10px; text-align:center;';
            box.innerHTML = '<div style="font-size:20px; font-weight:600; font-family:\'Cormorant Garamond\',serif; color:' + (isHot ? 'var(--gold)' : 'var(--text)') + ';">' + count + '</div><div style="font-size:10px; color:var(--muted); font-family:\'DM Sans\',sans-serif; margin-top:2px;">' + stage + '</div>';
            grid.appendChild(box);
          }
          allContainer.appendChild(grid);
          container.appendChild(allContainer);
        }
      } catch(e) {}
    }

    // ── STU Chat ──
    const STU_ENDPOINT = 'https://flowise.strsolutionsusa.com/api/v1/prediction/2955e532-d156-4648-8a38-6a645f37cc43';
    let stuSessionId = null;

    function appendMsg(containerId, text, isUser) {
      const container = document.getElementById(containerId);
      const div = document.createElement('div');
      div.style.cssText = 'background:' + (isUser ? 'var(--accent-soft)' : 'var(--gold-soft)') + '; border:1px solid var(--border); border-radius:10px; padding:10px 14px; align-self:' + (isUser ? 'flex-end' : 'flex-start') + '; max-width:85%; font-size:13px; line-height:1.5; white-space:pre-wrap; word-wrap:break-word; font-family:\'DM Sans\',sans-serif;';
      div.textContent = text;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;
      return div;
    }

    async function sendSTU() {
      const input = document.getElementById('stu-input');
      const q = input.value.trim();
      if (!q) return;
      input.value = '';
      appendMsg('stu-messages', q, true);
      const thinking = appendMsg('stu-messages', '\u2026', false);
      try {
        const body = { question: q };
        if (stuSessionId) body.overrideConfig = { sessionId: stuSessionId };
        const r = await fetch(STU_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const d = await r.json();
        thinking.textContent = d.text || d.error || JSON.stringify(d);
        if (d.sessionId) stuSessionId = d.sessionId;
      } catch(e) {
        thinking.textContent = 'Error: ' + e.message;
        thinking.style.color = 'var(--danger)';
      }
    }

    function stuQuick(q) {
      document.getElementById('stu-input').value = q;
      sendSTU();
    }

    // ── Claude Chat ──
    async function sendClaude() {
      const input = document.getElementById('claude-input');
      const q = input.value.trim();
      if (!q) return;
      input.value = '';
      appendMsg('claude-messages', q, true);
      const thinking = appendMsg('claude-messages', '\u2026', false);
      try {
        const r = await fetch('/api/claude', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: q })
        });
        const d = await r.json();
        thinking.textContent = d.text || d.content?.[0]?.text || d.error || JSON.stringify(d);
      } catch(e) {
        thinking.textContent = 'Claude not yet connected. Add ANTHROPIC_API_KEY to activate.';
        thinking.style.color = 'var(--warn)';
      }
    }

    // ── Auto refresh ──
    function autoRefresh() {
      loadKPIs();
      loadServices();
      loadContext();
      loadSkills();
      loadFlowiseHealth();
      loadFlowiseStats();
      setInterval(() => {
        loadKPIs();
        loadServices();
        loadContext();
        loadSkills();
        loadFlowiseHealth();
        loadFlowiseStats();
      }, refreshInterval);
    }
    scheduleCountdown();
    autoRefresh();
  </script>
</body>
</html>
